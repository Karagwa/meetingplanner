
# Java.gitignore - comprehensive template for Java projects
# Recommended to customize for your project specifics

# Compiled class files
*.class

# Log files
*.log
logs/

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz

# Virtual machine crash logs
hs_err_pid*

# Maven
/target/
/dependency-reduced-pom.xml
/release.properties
/pom.xml.tag
/pom.xml.releaseBackup
/pom.xml.versionsBackup
/pom.xml.next
buildNumber.properties
.mvn/timing.properties

# Gradle
.gradle/
/build/
# keep Gradle wrapper jar (important to build on CI)
!gradle/wrapper/gradle-wrapper.jar
!**/gradle-wrapper.jar

# Eclipse
.classpath
.project
.settings/
.factorypath
.metadata/

# IntelliJ IDEA
*.iml
.idea/
out/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary files
*~
*.tmp
*.bak
*.swp

# Environment and secret files
.env
.env.*
local.properties
secrets.properties
credentials.properties
*.jks
*.keystore

# Test and coverage reports
coverage/
jacoco.exec
target/site/jacoco/
*.lcov

# Generated files
generated/
gen/

# Dependency directories
lib/
libs/

# IDE/task runner caches
.gradle*

# Jetty / Tomcat
logs/
*.log

# Other
*.class
*.war
*.ear
*.jar

# Ignore build artifacts and temporary files commonly produced by tools
build/
out/

# End of file
